# Copy this file to `.env` and adapt values for your machine or test environment.

# --- PostgreSQL ---
POSTGRES_CONTAINER_NAME=postgres-dev
POSTGRES_USER=professor-oak
POSTGRES_PASSWORD=gottacatchthemall
POSTGRES_DB=pokedex_database
POSTGRES_PORT=5444

# --- Backend container ---
API_CONTAINER_NAME=pokedex-api-dev
API_PORT=8082
SPRING_DATASOURCE_URL=jdbc:postgresql://mi-postgres:5432/pokedex_database
SPRING_DATASOURCE_USERNAME=professor-oak
SPRING_DATASOURCE_PASSWORD=gottacatchthemall
INTEGRATION_POKEAPI_BASE_URL=https://pokeapi.co/api/v2
INTEGRATION_POKEAPI_CONNECT_TIMEOUT_MS=7000
INTEGRATION_POKEAPI_READ_TIMEOUT_MS=20000
INTEGRATION_POKEAPI_ENABLED=true

# Optional for corporate networks when the container must trust a custom Java truststore.
# Example:
# JAVA_TOOL_OPTIONS=-Djavax.net.ssl.trustStore=/app/certs/company-truststore.jks -Djavax.net.ssl.trustStorePassword=changeit
JAVA_TOOL_OPTIONS=

# --- Frontend container ---
FRONTEND_CONTAINER_NAME=pokedex-frontend-dev
FRONTEND_PORT=4200

